    "url": "https://github.com/dudhatparesh/terminalx-app-mono/issues"
  },
  "homepage": "https://github.com/dudhatparesh/terminalx-app-mono#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx server/index.ts",
    "dev:next": "next dev",
    "build": "next build",
    "start": "NODE_ENV=production tsx server/index.ts",
    "start:next": "next start",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "@wterm/core": "file:vendor/wterm/wterm-core-0.1.8.tgz",
    "@wterm/dom": "file:vendor/wterm/wterm-dom-0.1.8.tgz",
    "@wterm/just-bash": "file:vendor/wterm/wterm-just-bash-0.1.8.tgz",
    "@wterm/markdown": "file:vendor/wterm/wterm-markdown-0.1.8.tgz",
    "@wterm/react": "file:vendor/wterm/wterm-react-0.1.8.tgz",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "bcryptjs": "^3.0.3",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "grammy": "^1.42.0",
    "jose": "^6.2.2",
    "just-bash": "^2.14.2",
    "lucide-react": "^1.8.0",
    "next": "^16.2.3",
    "node-pty": "^1.1.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-resizable-panels": "^4.10.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "ws": "^8.20.0",
    "xterm": "^5.3.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "eslint": "^9",
    "eslint-config-next": "^16.2.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.4.2",
    "shadcn": "^4.3.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "postcss": "8.5.12",
    "hono": ">=4.12.12",
    "@hono/node-server": ">=1.19.13"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs,json,md,yml,yaml}": "prettier --write",
    "*.{ts,tsx,js,mjs,cjs}": "eslint --fix"
  }
}
