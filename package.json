{
  "name": "terminalx-app-mono",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hosted terminal IDE for the browser — tmux sessions, file browser, log tailing, and AI-CLI playgrounds from a modern web UI.",
  "license": "MIT",
  "author": "TerminalX Contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dudhatparesh/terminalx-app-mono.git"
  },
